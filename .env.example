# Copy this file to ".env" in the project root, fill in values, then restart "npm run dev".
# Supabase: Dashboard → Project Settings → API → Project URL + anon public key.
# Server (.env): service role is for server.js only — never put it in VITE_* or the browser.

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Required for sign-in / sync in the browser (Vite). Without these, you see "Missing Supabase client env vars".
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key
# Optional alias for server /api/client-env only (same value as anon key):
# SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Render / production: if you did not set VITE_* at build time, set SUPABASE_URL + VITE_SUPABASE_ANON_KEY
# (or SUPABASE_ANON_KEY) on the web service — the app loads them at runtime via GET /api/client-env.

# AI — server.js only (browser talks to /api/*, which calls Ollama).
#
# Option A — Ollama Cloud (Render + production): https://ollama.com + API key
OLLAMA_URL=https://ollama.com
OLLAMA_API_KEY=your-ollama-api-key
OLLAMA_MODEL=gpt-oss:120b
#
# Option B — Local Ollama: install from https://ollama.com then ollama pull qwen2.5:7b
# OLLAMA_URL=http://127.0.0.1:11434
# OLLAMA_API_KEY=
# OLLAMA_MODEL=qwen2.5:7b
#
# Remote self-hosted or ngrok tunnel to local Ollama: OLLAMA_URL=https://xxxx.ngrok-free.dev (no trailing slash)
# Large PDF ingestion can exceed 45s on local models — 120000–300000 is typical.
OLLAMA_TIMEOUT_MS=120000
# Keep model loaded in VRAM between generate calls (Ollama). Examples: 5m, 30m, -1
OLLAMA_KEEP_ALIVE=5m
# RAG: Ollama embeddings (pull with: ollama pull nomic-embed-text). Dimension must match migration 0010 (768).
OLLAMA_EMBED_MODEL=nomic-embed-text
# OLLAMA_EMBED_DIM=768
# MAX_RAG_EMBED_CHUNKS=48
# OLLAMA_EMBED_TIMEOUT_MS=90000

# Vercel — REST API token (server.js only). Create at https://vercel.com/account/tokens — add the same name/value under Vercel → Project → Environment Variables for production.
# Never use VITE_* for this key (it would be exposed in the browser).
VERCEL_API_KEY=

# Optional: email reminders for tasks (1h + 10m before due). Requires Node API server running.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Krea <noreply@example.com>"
